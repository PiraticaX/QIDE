# ── Quantum Enterprise Platform — Backend Environment Variables ──────────────
# Copy this file to .env and fill in your values

# App
DEBUG=false
FRONTEND_URL=http://localhost:3000

# Database
# SQLite (default for local dev — no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./quantum_platform.db

# PostgreSQL (for production — uncomment and fill in):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/quantum_platform

# Redis (optional — for caching and job queues)
# REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE THIS in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email (OTP delivery)
# Leave blank for dev — OTPs will print to console logs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@your-domain.com

# Optional: Sentry error tracking
# SENTRY_DSN=https://...
